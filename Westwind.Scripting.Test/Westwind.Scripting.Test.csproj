    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Scripting" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Scripting.Common" Version="5.3.0" />
    
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ReferenceTest\ReferenceTest.csproj" />
    <ProjectReference Include="..\Westwind.Scripting\Westwind.Scripting.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Update="templates\**\*.*">
